{
  "compilerOptions": {
    "composite": true,
    "esModuleInterop": true,
    "isolatedModules": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "strict": true,
    "target": "ES2022",
    "useUnknownInCatchVariables": false,
    "noImplicitAny": true,
    "sourceMap": true,
    "outDir": "dist/tsc"
  },
  "include": ["src/**/*"]
}
